{
    "name": "jp3cki/ipv4.fetus.jp",
    "description": "ipv4.fetus.jp",
    "license": "MIT",
    "type": "project",
    "homepage": "https://ipv4.fetus.jp/",
    "support": {
        "issues": "https://github.com/fetus-hina/ipv4.fetus.jp/issues",
        "source": "https://github.com/fetus-hina/ipv4.fetus.jp"
    },
    "require": {
        "php": ">= 8.4",
        "php-64bit": "*",
        "php-ipv6": "*",
        "ext-curl": "*",
        "ext-date": "*",
        "ext-dom": "*",
        "ext-hash": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-pcre": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-session": "*",
        "ext-spl": "*",
        "cweagans/composer-patches": "^1.7.3",
        "lipis/flag-icons": "^7.5.0",
        "matomo/device-detector": "^6.5.0",
        "statink/yii2-sortable-table": "^1.0.3",
        "twbs/bootstrap-icons": "^1.13.1",
        "yiisoft/yii2": "^2.0.55",
        "yiisoft/yii2-bootstrap5": "^2.0.51",
        "yiisoft/yii2-httpclient": "^2.0.16"
    },
    "require-dev": {
        "codeception/codeception": "^5.3.5",
        "codeception/module-asserts": "^3.2.1",
        "codeception/module-filesystem": "^3.0.2",
        "codeception/module-yii2": "^1.1.12 || ^2.0.5",
        "codeception/specify": "^2.0.0",
        "codeception/verify": "^3.4.0",
        "ergebnis/composer-normalize": "^2.52.0",
        "erickskrauch/phpstan-yii2": "dev-master",
        "jp3cki/coding-standard": "^2.0.0",
        "squizlabs/php_codesniffer": "^4.0.1",
        "symfony/browser-kit": "^6.4.32 || ^7.0.0 || ^8.0.0",
        "yiisoft/yii2-debug": "^2.1.28",
        "yiisoft/yii2-gii": "^2.2.7"
    },
    "replace": {
        "bower-asset/bootstrap": "*",
        "bower-asset/inputmask": "*",
        "bower-asset/jquery": "*",
        "bower-asset/punycode": "*",
        "bower-asset/yii2-pjax": "*",
        "npm-asset/bootstrap": "*",
        "npm-asset/stupid-table-plugin": "*",
        "paragonie/random_compat": "*",
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-php70": "*",
        "symfony/polyfill-php71": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "repositories": {
        "statink": {
            "type": "composer",
            "url": "https://satis.stat.ink"
        }
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "app\\": "./"
        }
    },
    "config": {
        "allow-plugins": {
            "cweagans/composer-patches": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "yiisoft/yii2-composer": true
        },
        "platform": {
            "php": "8.4.21"
        },
        "process-timeout": 1800
    },
    "extra": {
        "patches": {
            "erickskrauch/phpstan-yii2": {
                "fix: ComponentPropertyReflection getReadableType returning mixed on PHPStan 2.x": "data/patches/composer/erickskrauch/phpstan-yii2/fix-component-property-reflection-readable-type.patch"
            }
        }
    },
    "scripts": {
        "post-install-cmd": [
            "[ $COMPOSER_DEV_MODE -eq 0 ] || ./vendor/bin/codecept build",
            "./yii license/clean-extracted",
            "./yii license/extract"
        ],
        "post-update-cmd": [
            "[ $COMPOSER_DEV_MODE -eq 0 ] || ./vendor/bin/codecept build",
            "./yii license/clean-extracted",
            "./yii license/extract"
        ]
    }
}
